@model CloneProm.Models.Product

<div class="product-form-wrapper">

    <div class="form-card">
        <h2 class="form-title">Редагування товару</h2>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-input" />
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-input form-textarea"></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Price"></label>
                    <input asp-for="Price" class="form-input" />
                </div>

                <div class="form-group">
                    <label asp-for="Discount"></label>
                    <input asp-for="Discount" class="form-input" />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Quantity"></label>
                <input asp-for="Quantity" class="form-input" />
            </div>

            <div class="form-group">
                <label>Змінити зображення</label>
                <input type="file" name="imageFile" class="form-input" />
                <div class="current-image">
                    <img src="@Model.ImagePath" />
                </div>
            </div>

            <div class="form-group">
                <label>Категорія</label>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-input"></select>
            </div>

            <button type="submit" class="btn-main">Зберегти зміни</button>
        </form>
    </div>
</div>