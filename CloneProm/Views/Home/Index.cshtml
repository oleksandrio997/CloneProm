@model CloneProm.Models.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<!-- TOP WORK AREA -->
<div class="top-work-area mb-5">

    <!-- LEFT CATEGORIES -->
    <div class="left-categories">
        <div class="category-menu">

            <a class="category-item @(Model.SelectedCategoryId == null ? "active" : "")"
               href="@Url.Action("Index", "Home")">
                <span>All</span>
                <span class="arrow">›</span>
            </a>

            @foreach (var category in Model.Categories)
            {
                var isActive = Model.SelectedCategoryId.HasValue &&
                Model.SelectedCategoryId.Value == category.Id
                ? "active" : "";

                <a class="category-item @isActive"
                   href="@Url.Action("Index", "Home", new { category = category.Id })">
                    <span>@category.Name</span>
                    <span class="arrow">›</span>
                </a>
            }

        </div>
    </div>

    <!-- CENTER BANNER -->
    <div class="center-banner">
        <!-- просто серая зона -->
    </div>

    <!-- RIGHT HARDCODE BLOCK -->
    <div class="right-business-block">
        <div class="business-box">
            <div class="business-image"></div>

            <h6 class="mt-3 text-center">
                Почніть свій бізнес на<br />
                <strong>KRAM</strong> вже сьогодні
            </h6>

            <p class="small text-center text-muted">
                Отримайте доступ до найбільшої бази покупців
            </p>

            <button class="btn btn-secondary w-100">
                Почати бізнес
            </button>
        </div>
    </div>

</div>


<!-- PRODUCTS -->
<div class="row">
    <div class="col-12">
        <div class="row">
            @if (Model.Products != null && Model.Products.Any())
            {
                @foreach (var product in Model.Products)
                {
                    <partial name="_ProductCard" model="product" />
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-info">No products found.</div>
                </div>
            }
        </div>
    </div>
</div>