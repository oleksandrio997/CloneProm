@model CloneProm.Models.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<!-- TOP WORK AREA -->
<div class="top-work-area mb-5">

    <!-- LEFT CATEGORIES -->
    <div class="left-categories">
        <div class="category-menu">

            <a class="category-item @(Model.SelectedCategoryId == null ? "active" : "")"
               href="@Url.Action("Index", "Home")">
                <span class="category-content">
                    <i class="fa-solid fa-border-all category-icon"></i>
                    <span>All</span>
                </span>
                <span class="arrow">›</span>
            </a>

            @foreach (var category in Model.Categories)
            {
                var isActive = Model.SelectedCategoryId.HasValue &&
                Model.SelectedCategoryId.Value == category.Id
                ? "active" : "";

                <a class="category-item @isActive"
                   href="@Url.Action("Index", "Home", new { category = category.Id })">

                    <span class="category-content">

                        @if (category.Name.Contains("Elect"))
                        {
                            <i class="fa-solid fa-plug category-icon"></i>
                        }
                        else if (category.Name.Contains("Home"))
                        {
                            <i class="fa-solid fa-house category-icon"></i>
                        }
                        else if (category.Name.Contains("Book"))
                        {
                            <i class="fa-solid fa-book category-icon"></i>
                        }
                        else if (category.Name.Contains("Cloth"))
                        {
                            <i class="fa-solid fa-shirt category-icon"></i>
                        }
                        else if (category.Name.Contains("Toy"))
                        {
                            <i class="fa-solid fa-gamepad category-icon"></i>
                        }
                        else
                        {
                            <i class="fa-solid fa-circle category-icon"></i>
                        }

                        <span>@category.Name</span>
                    </span>

                    <span class="arrow">›</span>
                </a>
            }

        </div>
    </div>
    <!-- CENTER BANNER -->
    <!-- CENTER BANNER -->
    <div class="center-banner">
        <img src="/images/home/MegaBanner.jpg" alt="Banner">
    </div>


    <!-- RIGHT HARDCODE BLOCK -->
    <div class="right-business-block">

        <div class="business-box">

            <div class="business-image">
                <img src="/images/home/Busnes.jpg" alt="Business">
            </div>

            <h6 class="mt-3 text-center">
                Почніть свій бізнес на<br />
                <strong>KRAM</strong> вже сьогодні
            </h6>

            <p class="small text-center text-muted">
                Отримайте доступ до найбільшої бази покупців
            </p>

            <button class="btn btn-secondary w-100">
                Почати бізнес
            </button>

        </div>

    </div>

</div>

<!-- POPULAR CATEGORIES (HARDCODE VISUAL BLOCK) -->
<div class="popular-categories-section mt-5 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Популярні категорії</h5>

        <div class="popular-arrows">
            <button class="arrow-btn">‹</button>
            <button class="arrow-btn">›</button>
        </div>
    </div>

    <div class="popular-categories-wrapper">

        <div class="popular-category-item">
            <div class="popular-category-img">
                <img src="~/images/popular/electronics.jpg" alt="Електроніка">
            </div>
            <p>Техніка та електроніка</p>
        </div>

        <div class="popular-category-item">
            <div class="popular-category-img">
                <img src="~/images/popular/clothes.jpg" alt="Одяг">
            </div>
            <p>Взуття та одяг</p>
        </div>

        <div class="popular-category-item">
            <div class="popular-category-img">
                <img src="~/images/popular/beauty.jpg" alt="Краса">
            </div>
            <p>Краса та здоров'я</p>
        </div>

        <div class="popular-category-item">
            <div class="popular-category-img">
                <img src="~/images/popular/supplements.jpg" alt="Біодобавки">
            </div>
            <p>Біодобавки</p>
        </div>

        <div class="popular-category-item">
            <div class="popular-category-img">
                <img src="~/images/popular/home.jpg" alt="Дім і сад">
            </div>
            <p>Дім і сад</p>
        </div>

        <div class="popular-category-item">
            <div class="popular-category-img">
                <img src="~/images/popular/textile.jpg" alt="Текстиль">
            </div>
            <p>Текстиль і одяг</p>
        </div>

        <div class="popular-category-item">
            <div class="popular-category-img">
                <img src="~/images/popular/kids.jpg" alt="Діти">
            </div>
            <p>Товари для дітей</p>
        </div>

        <div class="popular-category-item">
            <div class="popular-category-img">
                <img src="~/images/popular/perfume.jpg" alt="Парфумерія">
            </div>
            <p>Парфумерія</p>
        </div>

        <div class="popular-category-item">
            <div class="popular-category-img">
                <img src="~/images/popular/repair.jpg" alt="Ремонт">
            </div>
            <p>Матеріали для ремонту</p>
        </div>

    </div>
</div>

<!-- PRODUCTS -->
<h1 class="mb-0">Товари</h1>

<div class="row">
    <div class="col-12">
        <div class="row">
            @if (Model.Products != null && Model.Products.Any())
            {
                @foreach (var product in Model.Products)
                {
                    <partial name="_ProductCard" model="product" />
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-info">No products found.</div>
                </div>
            }
        </div>
    </div>
</div>

<div class="custom-pagination">

    @if (Model.CurrentPage > 1)
    {
        <a class="page-btn prev"
           href="@Url.Action("Index", new { page = Model.CurrentPage - 1, category = Model.SelectedCategoryId, q = Model.SearchQuery })">
            ‹ Назад
        </a>
    }

    @for (int i = 1; i <= Model.TotalPages; i++)
    {
        if (i == Model.CurrentPage)
        {
            <span class="page-number active">@i</span>
        }
        else
        {
            <a class="page-number"
               href="@Url.Action("Index", new { page = i, category = Model.SelectedCategoryId, q = Model.SearchQuery })">
                @i
            </a>
        }
    }

    @if (Model.CurrentPage < Model.TotalPages)
    {
        <a class="page-btn next"
           href="@Url.Action("Index", new { page = Model.CurrentPage + 1, category = Model.SelectedCategoryId, q = Model.SearchQuery })">
            Вперед ›
        </a>
    }

</div>

<section class="benefits-section">

    <div class="benefits-container">

        <div class="benefit-item">
            <img src="/images/home/payment.png" alt="Оплата">
            <h6>100% безпечні платежі</h6>
            <p>
                Оплачуй карткою, Apple Pay або<br>
                Google Pay без жодних ризиків.
            </p>
        </div>

        <div class="benefit-item">
            <img src="/images/home/delivery.png" alt="Доставка">
            <h6>Швидка доставка</h6>
            <p>
                Обирайте зручний спосіб: у<br>
                відділення, поштомат або кур'єром.
            </p>
        </div>

        <div class="benefit-item">
            <img src="/images/home/bonus.png" alt="Бонуси">
            <h6>Бонуси за покупку</h6>
            <p>
                Кешбек, персональні пропозиції та<br>
                ексклюзивні знижки вже чекають.
            </p>
        </div>

        <div class="benefit-item">
            <img src="/images/home/return.png" alt="Повернення">
            <h6>Гарантія повернення</h6>
            <p>
                Ми дбаємо про те, щоб покупки<br>
                приносили лише задоволення.
            </p>
        </div>

    </div>

</section>

<style>
    .custom-pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 14px;
        margin-top: 40px;
    }

    .page-number {
        width: 48px;
        height: 48px;
        border: 1px solid #d9d9d9;
        background: white;
        border-radius: 12px;
        font-size: 16px;
        cursor: pointer;
        transition: 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: black;
    }

        .page-number:hover {
            border-color: #000;
        }

        .page-number.active {
            border: 2px solid #000;
            font-weight: 600;
        }

    .page-btn {
        height: 48px;
        padding: 0 20px;
        border: 1px solid #d9d9d9;
        background: white;
        border-radius: 12px;
        font-size: 16px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: black;
    }

        .page-btn:hover {
            border-color: #000;
        }

        .page-btn.disabled {
            color: #bfbfbf;
            border-color: #e5e5e5;
            cursor: default;
        }

    .dots {
        font-size: 18px;
        color: #999;
    }

    .benefits-section {
        padding: 50px 0;
        margin-top: 60px;
    }

    .benefits-container {
        max-width: 1200px;
        margin: auto;
        display: flex;
        justify-content: space-between;
        text-align: center;
    }

    .benefit-item {
        width: 22%;
    }

        .benefit-item img {
            width: 70px;
            margin-bottom: 15px;
        }

        .benefit-item h6 {
            font-weight: 600;
            margin-bottom: 8px;
        }

        .benefit-item p {
            font-size: 14px;
            color: #555;
        }
    body {
        background: #f4f4f4;;
	}
</style>