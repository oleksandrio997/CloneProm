@model CloneProm.Models.ApplicationUser

@{
    string activeTab = ViewBag.ActiveTab ?? "orders";
    var favorites = ViewBag.Favorites as List<CloneProm.Models.Product>;
    bool isSeller = ViewBag.IsSeller ?? false;
    bool isAdmin = ViewBag.IsAdmin ?? false;
    var products = ViewBag.Products as List<CloneProm.Models.Product>;
}

<div class="cabinet">

    <!-- Sidebar -->
    <aside class="cabinet-sidebar">

        <div class="user-block">

            <div class="user-avatar">
                <i class="bi bi-person"></i>
            </div>

            <div class="user-info">
                <div class="user-name">@Model.UserName</div>
                <div class="user-email">@Model.Email</div>
            </div>

        </div>

        <nav class="menu">

            <a asp-action="Index" asp-route-tab="orders"
               class="@(activeTab == "orders" ? "active" : "")">
                <i class="bi bi-box"></i> Мої замовлення
            </a>

            <a asp-action="Index" asp-route-tab="favorites"
               class="@(activeTab == "favorites" ? "active" : "")">
                <i class="bi bi-heart"></i> Бажане
            </a>

            <a asp-action="Index" asp-route-tab="notifications">
                <i class="bi bi-bell"></i> Сповіщення
            </a>

            <a asp-action="Index" asp-route-tab="reviews">
                <i class="bi bi-star"></i> Мої відгуки
            </a>

            <a asp-action="Index" asp-route-tab="tracking">
                <i class="bi bi-truck"></i> Відстеження замовлення
            </a>

            <a asp-action="Index" asp-route-tab="bonuses">
                <i class="bi bi-gift"></i> Знижки та бонуси
            </a>

            @if (isSeller || isAdmin)
            {
                <a asp-controller="Product" asp-action="Index"> <i class="bi bi-box-seam-fill"></i> Мої товари</a>
                <a asp-controller="Product" asp-action="Create"><i class="bi bi-plus-square"></i> Додати товар</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="BecomeSeller">
                    <i class="bi bi-person-add"></i> Стати продавцем
                </a>
            }

            <a asp-action="Index" asp-route-tab="settings">
                <i class="bi bi-gear"></i> Налаштування
            </a>

        </nav>

        <form asp-controller="Account" asp-action="Logout" method="post">
            <button class="logout">
                <i class="bi bi-box-arrow-right"></i> Вийти
            </button>
        </form>

    </aside>


    <!-- Content -->
    <main class="cabinet-content">

        @if (activeTab == "favorites")
        {
            <h2 class="page-title">Список бажань</h2>

            <div class="wishlist">

                @if (favorites == null || !favorites.Any())
                {
                    <div class="empty">
                        У вас ще немає товарів у списку бажань
                    </div>
                }
                else
                {
                    @foreach (var p in favorites)
                    {
                        <div class="wishlist-item">

                            <div class="wishlist-image">
                                <img src="@p.ImagePath" />
                            </div>

                            <div class="wishlist-info">

                                <div class="wishlist-title">
                                    @p.Name
                                </div>

                                <div class="wishlist-price">
                                    @p.Price.ToString("N2") ₴
                                </div>

                            </div>

                            <div class="wishlist-delete">
                                <i class="bi bi-trash"></i>
                            </div>

                        </div>
                    }
                }

            </div>
        }

    </main>

</div>

<style>
    body {
        background: #f5f6f7;
    }

    .cabinet {
        display: flex;
        gap: 30px;
        padding: 30px;
    }

    /* sidebar */

    .cabinet-sidebar {
        width: 260px;
        background: #fff;
        border-radius: 10px;
        padding: 20px;
    }

    .user-block {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-bottom: 15px;
        border-bottom: 1px solid #eee;
        margin-bottom: 20px;
    }

    .user-avatar {
        width: 42px;
        height: 42px;
        background: #eee;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .user-name {
        font-weight: 600;
    }

    .user-email {
        font-size: 13px;
        color: #777;
    }

    .menu {
        display: flex;
        flex-direction: column;
    }

        .menu a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            text-decoration: none;
            color: #333;
            font-size: 14px;
        }

            .menu a:hover {
                background: #f2f2f2;
            }

            .menu a.active {
                background: #f1f1f1;
                font-weight: 600;
            }

    .logout {
        margin-top: 20px;
        width: 100%;
        border: none;
        background: #f4f4f4;
        padding: 10px;
        border-radius: 8px;
    }

    /* content */

    .cabinet-content {
        flex: 1;
        background: #fff;
        border-radius: 10px;
        padding: 25px;
    }

    .page-title {
        margin-bottom: 20px;
    }

    /* wishlist */

    .wishlist {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 15px;
    }

    .wishlist-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px;
        background: #fafafa;
        border-radius: 10px;
    }

    .wishlist-image img {
        width: 70px;
        height: 70px;
        object-fit: contain;
        background: #fff;
        border: 1px solid #eee;
        padding: 4px;
    }

    .wishlist-info {
        flex: 1;
    }

    .wishlist-title {
        font-size: 14px;
        margin-bottom: 6px;
    }

    .wishlist-price {
        font-weight: 600;
    }

    .wishlist-delete {
        color: #999;
        cursor: pointer;
    }
</style>